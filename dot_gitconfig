[user]
    # TODO: Set these for your machine
    # name = Your Name
    # email = your@email.com
[core]
    editor = vim
    pager = less -R
    excludesfile = ~/.gitignore_global
    commentChar = ";"
    autocrlf = false
[color]
    ui = auto
[pull]
    rebase = true
[push]
    default = current
    autoSetupRemote = true
[init]
    defaultBranch = main
[diff]
    algorithm = histogram
[merge]
    conflictstyle = diff3
[rerere]
    enabled = true
[alias]
    st = status -sb
    co = checkout
    br = branch
    lg = log --oneline --graph --decorate --all
    dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)%an <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order
    unstage = reset HEAD --
    last = log -1 HEAD --stat
    amend = commit --amend --no-edit
[credential]
    helper = osxkeychain
